# Firebase Configuration (required)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef

# Server Configuration (required)
JWT_SECRET=generate_a_random_64_char_string_here
NODE_ENV=production
PORT=3000

# AI Configuration (optional — app works without it using advanced fallback)
GEMINI_API_KEY=your_gemini_api_key_optional

# Session Security (required in production)
SESSION_SECRET=generate_another_random_64_char_string
